# ============================================================
# Hara Tech API - Configuracao de Ambiente
# ============================================================
# Copie este arquivo como .env e preencha os valores.
#   Linux/Mac: cp .env.example .env
#   Windows:   Copy-Item .env.example .env
# ============================================================

# --- Banco de Dados ---
# PostgreSQL connection string
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/haratech?schema=public"

# --- Autenticacao JWT ---
# Secret para assinar os tokens JWT (gerar com: openssl rand -hex 32)
JWT_SECRET="troque-por-um-segredo-forte-com-pelo-menos-32-caracteres"
# Tempo de expiracao do token (ex: 7d, 24h, 60m)
JWT_EXPIRES_IN="7d"

# --- Servidor ---
# Porta onde a API sera executada
PORT=3000
# Ambiente: development | production | test
NODE_ENV="development"

# --- Provisionamento de Dispositivos ---
# Segredo compartilhado usado pelo ESP32 para se registrar na API.
# Deve ser o mesmo valor no firmware (PROVISIONING_SECRET).
# Em producao, gere um valor forte com: openssl rand -hex 32
DEVICE_PROVISIONING_SECRET="troque-por-um-segredo-de-provisionamento-forte"

# --- Online Window ---
# Janela de tempo (em segundos) desde o ultimo heartbeat
# para considerar o dispositivo como online.
DEVICE_ONLINE_WINDOW_SECONDS=120
